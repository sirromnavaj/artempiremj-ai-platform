---
import Base from '../../layouts/Base.astro';
import { EVENTS, type ArtEvent } from '../../data/events.ts';
const events: ArtEvent[] = [...EVENTS].sort((a, b) => ((a.start ?? '9999') < (b.start ?? '9999') ? -1 : 1));
const MO = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmt = (d?: string) => { if (!d) return ''; const [y, m, dd] = d.split('-'); return `${+dd} ${MO[+m - 1]} ${y}`; };
const dates = (e: ArtEvent) => e.window ?? (e.end ? `${fmt(e.start)} to ${fmt(e.end)}` : fmt(e.start));
const site = 'https://artempiremj.com';
const itemList = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: 'Art events worth a trip, worldwide',
  itemListElement: events.map((e, i) => ({ '@type': 'ListItem', position: i + 1, name: e.title, url: e.url })),
};
---
<Base path="/itineraries" title="Art Itineraries" description="The biennials, fairs, and museum shows worth crossing the world for, worldwide, with the dates to plan around. Africa first-class. Art travel for the culturally-curious.">
  <set:html set:html={`<script type="application/ld+json">${JSON.stringify(itemList)}</script>`} />
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="eyebrow">Art Itineraries</p>
    <h1>Be there the week the art is.</h1>
    <p class="lede prose">The biennials, fairs, and museum shows worth crossing the world for, with the
      dates to plan around so you book before the rooms fill. Dakar to Venice, Lagos to New York.</p>
  </section>

  <section class="wrap" style="padding-block: 1rem 3rem;">
    <ul class="events">
      {events.map((e) => (
        <li class="ev">
          <a href={e.url} rel="noopener" target="_blank">
            <span class="eyebrow">{e.region}{e.verified ? '' : ' · dates to confirm'}</span>
            <span class="ev-title">{e.title}</span>
            <span class="ev-when">{dates(e)}</span>
            <span class="muted">{e.venue} · {e.city}, {e.country}</span>
            <span class="ev-why">{e.why}</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="muted prose" style="margin-top:2rem;border-top:1px solid var(--line);padding-top:1.4rem;">
      Dates are verified against each event’s own source before listing. Routes around the strongest
      of these, what to see, who to meet, where the art actually is, follow next.</p>
  </section>

  <style>
    .events { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(330px, 1fr)); gap: 1.1rem; }
    .ev { border: 1px solid var(--line); border-radius: 4px; background: var(--paper); transition: border-color 0.15s; }
    .ev:hover { border-color: var(--ember); }
    .ev a { display: grid; gap: 0.3rem; padding: 1.3rem; text-decoration: none; }
    .ev-title { font-family: var(--display); font-weight: 600; font-size: 1.3rem; line-height: 1.15; }
    .ev-when { font-family: var(--sans); font-size: 0.85rem; color: var(--ember); font-weight: 600; }
    .ev-why { font-size: 1rem; color: var(--ink-soft); margin-top: 0.2rem; }
  </style>
</Base>
