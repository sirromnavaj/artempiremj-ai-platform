---
import Base from '../../layouts/Base.astro';
import { OPPORTUNITIES } from '../../data/calendar.ts';
import { EVENTS } from '../../data/events.ts';

export function getStaticPaths() {
  const slug = (s) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  const cities = new Map();
  for (const o of OPPORTUNITIES) if (!cities.has(slug(o.city))) cities.set(slug(o.city), { name: o.city, country: o.country });
  for (const e of EVENTS) if (!cities.has(slug(e.city))) cities.set(slug(e.city), { name: e.city, country: e.country });
  return [...cities].map(([s, meta]) => ({
    params: { city: s },
    props: {
      name: meta.name, country: meta.country,
      opps: OPPORTUNITIES.filter((o) => slug(o.city) === s),
      events: EVENTS.filter((e) => slug(e.city) === s),
    },
  }));
}
const { name, country, opps, events } = Astro.props;
const MO = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmt = (d) => { if (!d) return ''; const [y, m, dd] = d.split('-'); return `${+dd} ${MO[+m - 1]} ${y}`; };
const kindLabel = { 'open-call': 'Open call', residency: 'Residency', grant: 'Grant', fair: 'Fair', biennial: 'Biennial', prize: 'Prize' };
// Only cities we have real, honest photography for get a hero image.
const cityImage: Record<string, { src: string; alt: string; credit: string }> = {
  'johannesburg': { src: '/images/khethiwe_fnb_artjoburg_aerial.jpg', alt: 'FNB Art Joburg fair floor', credit: 'Khethiwe Tracy Gumede' },
  'cape-town': { src: '/images/ictaf_southern_guild.jpg', alt: 'The Southern Guild booth at the Investec Cape Town Art Fair', credit: 'ICTAF' },
};
const img = cityImage[Astro.params.city];
---
<Base path={`/city/${Astro.params.city}`} title={`Art in ${name}`}
  description={`What is on in ${name}: the fairs, biennials, and museum shows worth a trip, and the open calls, residencies, and grants for artists there.`}>
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="muted" style="font-family:var(--sans);font-size:0.85rem;"><a href="/">Calendar</a> · {country}</p>
    <h1>What is on in {name}</h1>
    <p class="lede prose">Everything ArtempireMJ is tracking in {name}: what to see if you are going,
      and what to apply to if you make the work.</p>
  </section>

  {img && (
    <figure class="city-hero">
      <img src={img.src} alt={img.alt} width="1600" height="760" loading="eager" decoding="async" />
      <figcaption class="muted">{name}. Photograph by {img.credit}.</figcaption>
    </figure>
  )}

  {events.length > 0 && (
    <section class="wrap" style="padding-block: 1rem;">
      <h2>To see</h2>
      <ul class="rows">
        {events.map((e) => (
          <li class="row"><a href={e.url} rel="noopener" target="_blank">
            <span class="r-name">{e.title}</span>
            <span class="r-when">{e.window ?? (e.end ? `${fmt(e.start)} to ${fmt(e.end)}` : fmt(e.start))}</span>
            <span class="muted">{e.venue}</span>
          </a></li>
        ))}
      </ul>
    </section>
  )}

  {opps.length > 0 && (
    <section class="wrap" style="padding-block: 1rem 3rem;">
      <h2>To apply to</h2>
      <ul class="rows">
        {opps.map((o) => (
          <li class="row"><a href={`/opportunity/${o.id}`}>
            <span class="eyebrow">{kindLabel[o.kind]}</span>
            <span class="r-name">{o.title}</span>
            <span class="muted">{o.organizer} · {o.verified && o.deadline ? `Deadline ${o.deadline}` : o.window}</span>
          </a></li>
        ))}
      </ul>
    </section>
  )}

  <section class="wrap" style="padding-block: 0 3rem;">
    <p class="muted"><a href="/calendar">Search every city and opportunity</a></p>
  </section>

  <style>
    .rows { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; gap: 0.7rem; }
    .row { border: 1px solid var(--line); border-radius: 4px; background: var(--paper); }
    .row a { display: grid; gap: 0.25rem; padding: 1rem 1.2rem; text-decoration: none; }
    .row:hover { border-color: var(--orange); }
    .r-name { font-family: var(--display); font-weight: 600; font-size: 1.25rem; }
    .r-when { font-family: var(--sans); font-size: 0.85rem; color: var(--ember); font-weight: 600; }
    .city-hero { margin: 0 auto 1rem; max-width: 72rem; padding-inline: var(--pad); }
    .city-hero img { width: 100%; height: auto; aspect-ratio: 21 / 9; object-fit: cover; border-radius: 4px; display: block; }
    .city-hero figcaption { margin-top: 0.4rem; font-size: 0.8rem; }
  </style>
</Base>
