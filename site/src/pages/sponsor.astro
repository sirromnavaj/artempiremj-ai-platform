---
import Base from '../layouts/Base.astro';
// Monetization framed on the skill's thesis (#21): not the art market (small, capped), but the
// far-wider audience about it. Diversified streams, the warm + Africa-first reach cold tools
// cannot offer. Editorial/coverage = the near-term money, sold on access and credibility.
const lines = [
  ['Editorial and coverage partners',
    'Fairs and institutions we cover on the ground, the way we covered ICTAF. Sold on access and credibility, not clicks. A coverage relationship, not an ad.'],
  ['Opportunity-givers',
    'Fairs, residencies, prizes, and grant-makers. List an open call on DISCOVER and reach the artists who want it. The artists are never charged. You reach them.'],
  ['The newsletter',
    'One warm, trusted email a week to a global art audience. Reach them in the inbox, with sends that can be aimed by region or discipline.'],
  ['Travel and lifestyle partners',
    'Reach the culturally-curious traveller through Art Itineraries, built around real dates on the calendar. The whole trip, not the airfare.'],
  ['Aligned brands and intelligence',
    'Painting and art-supply brands that belong beside the work. And the collectors and funders who read Art + Finance for what the market is doing.'],
];
---
<Base path="/sponsor" title="Partner with ArtempireMJ" description="Reach the wider world that follows art: artists, travellers, the culturally curious, and the diaspora, through DISCOVER, Spotlight, the newsletter, and Art Itineraries.">
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="eyebrow">For partners</p>
    <h1>Reach the world that follows art.</h1>
    <p class="lede prose">ArtempireMJ is free for the artists it serves, and read by a far wider world:
      travellers, collectors, the culturally curious, the diaspora. That free service is what makes
      it worth reaching them through. Warm, global, Africa first. Here is who partners with us.</p>
  </section>
  <section class="wrap" style="padding-block: 1rem 3rem;">
    <ul class="pay">
      {lines.map(([who, what]) => (
        <li><span class="s-name">{who}</span><span class="muted">{what}</span></li>
      ))}
    </ul>
    <p style="margin-top:1.5rem;"><a class="btn" href="mailto:partners@artempiremj.com">Start a conversation</a></p>
  </section>
  <style>
    .pay { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; gap: 1rem; max-width: 62ch; }
    .pay li { display: grid; gap: 0.3rem; padding: 1.2rem; border: 1px solid var(--line); border-radius: 3px; background: var(--cream); }
    .s-name { font-family: var(--serif); font-weight: 600; font-size: 1.2rem; }
  </style>
</Base>
