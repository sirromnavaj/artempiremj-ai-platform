---
import Base from '../layouts/Base.astro';
import Newsletter from '../components/Newsletter.astro';
import { OPPORTUNITIES, eventSchema, type Region } from '../data/calendar.ts';
import { ARTICLES } from '../data/articles.ts';
import { EVENTS } from '../data/events.ts';
import { FESTIVALS } from '../data/festivals.ts';
const citySlug = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const cityMap = new Map<string, string>();
for (const o of OPPORTUNITIES) cityMap.set(o.city, citySlug(o.city));
for (const e of EVENTS) cityMap.set(e.city, citySlug(e.city));
for (const f of FESTIVALS) cityMap.set(f.city, citySlug(f.city));
const cities = [...cityMap.entries()].map(([name, slug]) => ({ name, slug })).sort((a, b) => (a.name < b.name ? -1 : 1));
const featuredCities = ['Lagos', 'Cape Town', 'Venice', 'Dakar', 'London', 'Johannesburg'].map((n) => ({ name: n, slug: citySlug(n) }));
const MO = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const fmtE = (d?: string) => { if (!d) return ''; const [y, m, dd] = d.split('-'); return `${+dd} ${MO[+m - 1]} ${y}`; };
const upcomingEvents = [...EVENTS].sort((a, b) => ((a.start ?? '9999') < (b.start ?? '9999') ? -1 : 1)).slice(0, 3);

const regions: Region[] = ['Africa', 'Europe', 'Americas', 'Asia/Middle East'];
const closingSoon = OPPORTUNITIES
  .filter((o) => o.verified && o.deadline)
  .sort((a, b) => (a.deadline! < b.deadline! ? -1 : 1))
  .slice(0, 6);
const kindLabel: Record<string, string> = {
  'open-call': 'Open call', residency: 'Residency', grant: 'Grant',
  fair: 'Fair', biennial: 'Biennial', prize: 'Prize',
};
const gallery = [
  { src: '/images/khethiwe_tshabalala_bkhz_at_joburg.jpg', alt: 'Zandile Tshabalala’s show at the BKhz booth, FNB Art Joburg', credit: 'Khethiwe Tracy Gumede' },
  { src: '/images/ictaf_owanto.jpg', alt: 'Owanto’s solo presentation at Reiners Contemporary, Cape Town', credit: 'ICTAF' },
  { src: '/images/khethiwe_wunika_mukan_lagos_at_joburg.jpg', alt: 'Wunika Mukan Gallery of Lagos at FNB Art Joburg', credit: 'Khethiwe Tracy Gumede' },
  { src: '/images/ictaf_southern_guild.jpg', alt: 'The Southern Guild booth at the Investec Cape Town Art Fair', credit: 'ICTAF' },
  { src: '/images/ictaf_double_v.jpg', alt: 'The Double V Gallery booth at Cape Town', credit: 'ICTAF' },
  { src: '/images/khethiwe_sibande_sophie_at_joburg.jpg', alt: 'On the floor at FNB Art Joburg', credit: 'Khethiwe Tracy Gumede' },
  { src: '/images/ictaf_nosco.jpg', alt: 'The Gallery Nosco booth at Cape Town', credit: 'ICTAF' },
  { src: '/images/ictaf_investec_prize.jpg', alt: 'The Investec Emerging Artist Award at Cape Town', credit: 'ICTAF' },
];
const schema = OPPORTUNITIES.map(eventSchema);
const itemList = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: 'The Global Art Calendar',
  description: 'Open calls, residencies, grants, fairs, and biennials worldwide, gathered for artists and verified before they are listed.',
  numberOfItems: OPPORTUNITIES.length,
  itemListElement: OPPORTUNITIES.map((o, i) => ({
    '@type': 'ListItem', position: i + 1, name: o.title,
    url: `https://artempiremj.com/opportunity/${o.id}`,
  })),
};
---
<Base path="/" title="ArtempireMJ">
  <set:html set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
  <set:html set:html={`<script type="application/ld+json">${JSON.stringify(itemList)}</script>`} />

  <section class="hero-feature">
    <img class="hero-bg" src="/images/khethiwe_fnb_artjoburg_aerial.jpg"
         alt="FNB Art Joburg fair floor, seen from above"
         width="1600" height="900" loading="eager" decoding="async" />
    <div class="hero-cap">
      <div class="wrap">
        <p class="eyebrow hero-eyebrow">A correspondent on the floor</p>
        <h1>The world, told through artists.</h1>
      </div>
    </div>
  </section>

  <section class="wrap hero-intro">
    <p class="lede prose">Own history now. The banners said it across the floor at FNB Art Joburg, where
      fifteen African countries spent a week arguing, in paint and photographs, that the record of a
      place belongs to the people who live it. The same artists open the Global Art Calendar on Monday
      to find the next door, free.</p>
    <p class="muted">FNB Art Joburg. Photograph by Khethiwe Tracy Gumede, ArtempireMJ correspondent in South Africa.</p>
  </section>

  <section class="wrap trust-bar">
    <span class="tb"><strong>Every date verified</strong> before it is listed</span>
    <span class="tb"><strong>Reported from the floor</strong> by our correspondents</span>
    <span class="tb"><strong>Free</strong> for the artists it serves</span>
    <span class="tb"><strong>One email a week</strong>, the world in art</span>
  </section>

  <section class="wrap city-pick">
    <p class="eyebrow">Going somewhere?</p>
    <h2>See what is on, by city.</h2>
    <form id="city-form" class="city-form">
      <input id="city-input" list="city-list" placeholder="Type a city, like Lagos or Venice" aria-label="City" autocomplete="off" />
      <datalist id="city-list">{cities.map((c) => <option value={c.name}></option>)}</datalist>
      <button class="btn" type="submit">See what is on</button>
    </form>
    <p class="muted city-jump">Or jump to {featuredCities.map((c, i) => (<span><a href={`/city/${c.slug}`}>{c.name}</a>{i < featuredCities.length - 1 ? ' · ' : ''}</span>))} · <a href="/worldwide">see the whole map</a></p>
  </section>
  <script define:vars={{ cityData: Object.fromEntries(cities.map((c) => [c.name.toLowerCase(), c.slug])) }}>
    const f = document.getElementById('city-form');
    f && f.addEventListener('submit', (e) => {
      e.preventDefault();
      const v = (document.getElementById('city-input').value || '').trim().toLowerCase();
      location.href = cityData[v] ? '/city/' + cityData[v] : '/calendar';
    });
  </script>

  <section class="wrap calendar">
    <div class="cal-head">
      <h2>The Global Art Calendar</h2>
      <p class="muted prose">
        What is open right now, worldwide: open calls, residencies, grants, fairs, and biennials.
        Each one verified before it is listed, refreshed weekly. Artists find the door to apply to.
        Travellers find the fairs and biennials to plan a trip around, by city, on
        <a href="/itineraries">Art Itineraries</a>.
      </p>
      <p class="muted"><a href="/calendar">Search and filter the full calendar</a></p>
    </div>

    {closingSoon.length > 0 && (
      <div class="closing">
        <h3 class="region-name">Closing soon</h3>
        <ul class="ops">
          {closingSoon.map((o) => (
            <li class="op">
              <a class="op-link" href={`/opportunity/${o.id}`}>
                <span class="eyebrow">Deadline {o.deadline}</span>
                <span class="op-title">{o.title}</span>
                <span class="muted">{o.organizer} · {o.city}, {o.country}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {regions.map((region) => {
      const items = OPPORTUNITIES.filter((o) => o.region === region);
      if (items.length === 0) return null;
      return (
        <div class="region">
          <h3 class="region-name">{region}</h3>
          <ul class="ops">
            {items.map((o) => (
              <li class="op">
                <a class="op-link" href={`/opportunity/${o.id}`}>
                  <span class="eyebrow">{kindLabel[o.kind]}</span>
                  <span class="op-title">{o.title}</span>
                  <span class="muted">{o.organizer} · {o.city}, {o.country}</span>
                  <span class="op-summary">{o.summary}</span>
                  <span class="muted op-when">{o.verified && o.deadline ? `Deadline ${o.deadline}` : o.window}{o.verified && <span class="verified" style="margin-left:0.6rem;">Verified</span>}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      );
    })}

    <p class="muted cal-note">
      Browse the whole calendar, any time, beyond what we feature this week. By region:
      <a href="/region/africa">Africa</a>, <a href="/region/europe">Europe</a>,
      <a href="/region/americas">Americas</a>, <a href="/region/asia-middle-east">Asia and the Middle East</a>.
      By type: <a href="/type/residency">residencies</a>, <a href="/type/grant">grants</a>,
      <a href="/type/open-call">open calls</a>, <a href="/type/fair">fairs</a>,
      <a href="/type/biennial">biennials</a>, <a href="/type/prize">prizes</a>.
    </p>
    <p class="muted cal-note">
      Dates are confirmed before they are listed. Browse every opportunity on
      <a href="/discover">DISCOVER</a>, or <a href="/list">list yours</a>.
    </p>
  </section>

  <section class="wrap worth-trip">
    <h2>Worth a trip</h2>
    <p class="muted">For the traveller: the fairs, biennials, and museum shows to plan around.</p>
    <div class="trip-grid">
      {upcomingEvents.map((e) => (
        <a class="trip" href="/itineraries">
          <span class="eyebrow">{e.city}, {e.country}</span>
          <span class="trip-title">{e.title}</span>
          <span class="muted">{e.window ?? (e.end ? `${fmtE(e.start)} to ${fmtE(e.end)}` : fmtE(e.start))}</span>
        </a>
      ))}
    </div>
    <p class="muted" style="margin-top:1rem;"><a href="/festivals">Festivals</a> · <a href="/itineraries">all the art worth crossing the world for</a> · <a href="/travel">plan the trip</a> · <a href="/worldwide">the world map</a></p>
  </section>

  <section class="wrap latest">
    <h2>From the floor</h2>
    <div class="story-grid">
      {ARTICLES.map((a) => (
        <a class="story" href={`/story/${a.slug}`}>
          {a.image && <img src={a.image} alt={a.imageAlt} loading="lazy" decoding="async" />}
          <span class="eyebrow">{a.series}</span>
          <span class="story-title">{a.title}</span>
          <span class="muted">{a.dek}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="wrap gallery-band">
    <h2>On the floor</h2>
    <p class="muted">From our correspondents at the fairs this season.</p>
    <div class="gallery">
      {gallery.map((g) => (
        <figure class="gphoto">
          <img src={g.src} alt={g.alt} loading="lazy" decoding="async" />
          <figcaption class="muted">{g.credit}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="wrap convert">
    <div class="convert-card">
      <p class="eyebrow">The newsletter</p>
      <h2>The week in world art, in your inbox.</h2>
      <p class="prose">The open doors before they close. The makers worth knowing. The trips worth
        taking. One email a week, free.</p>
      <div class="sub-lg"><Newsletter variant="panel" /></div>
    </div>
  </section>

  <section class="wrap depts">
    <h2>Three ways in</h2>
    <div class="dept-grid">
      <a class="dept" href="/world">
        <span class="eyebrow">The World</span>
        <span class="dept-title">The world, through its artists</span>
        <span class="muted">War, currency, migration, identity, carried by the people who make the art.</span>
      </a>
      <a class="dept" href="/discover">
        <span class="eyebrow">DISCOVER</span>
        <span class="dept-title">The opportunity radar</span>
        <span class="muted">Open calls, residencies, grants, and fairs, gathered for the artists who want them.</span>
      </a>
      <a class="dept" href="/itineraries">
        <span class="eyebrow">Art Itineraries</span>
        <span class="dept-title">The world through what people make in it</span>
        <span class="muted">Art travel for the culturally-curious, built around the calendar.</span>
      </a>
    </div>
  </section>

  <style>
    .hero-feature { position: relative; }
    .hero-bg { width: 100%; height: min(66vh, 600px); min-height: 360px; object-fit: cover; object-position: 50% 40%; display: block; }
    .hero-cap { position: absolute; inset: 0; display: flex; align-items: flex-end;
      background: linear-gradient(to top, rgba(20,12,5,0.88) 0%, rgba(20,12,5,0.32) 42%, rgba(20,12,5,0.04) 70%, transparent 100%); }
    .hero-cap .wrap { width: 100%; padding-bottom: clamp(1.6rem, 4vw, 2.8rem); }
    .hero-cap h1 { color: var(--ivory); margin: 0.25rem 0 0; max-width: 20ch; text-shadow: 0 1px 30px rgba(0,0,0,0.45); }
    .hero-eyebrow { color: var(--warm-light); }
    .hero-intro { padding-block: 1.7rem 0.5rem; }
    .hero-intro .lede { max-width: 60ch; }
    .city-pick { padding-block: 1.6rem; border-top: 1px solid var(--line); }
    .city-form { display: flex; gap: 0.6rem; margin-top: 0.8rem; max-width: 40rem; flex-wrap: wrap; }
    .city-form input { flex: 1; min-width: 14rem; padding: 0.75em 1em; border: 1px solid var(--line); border-radius: 3px; font-family: var(--sans); font-size: 1rem; background: var(--paper); }
    .city-jump { margin-top: 0.8rem; }
    .trust-bar { display: flex; flex-wrap: wrap; gap: 0.5rem 1.6rem; padding-block: 1rem; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); font-family: var(--sans); font-size: 0.86rem; color: var(--muted); }
    .tb { display: inline-flex; align-items: center; gap: 0.4rem; }
    .tb::before { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--orange); flex: none; }
    .tb strong { color: var(--ink); font-weight: 600; }
    .verified { font-family: var(--sans); font-size: 0.66rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--teal); font-weight: 700; display: inline-flex; align-items: center; gap: 0.2rem; }
    .verified::before { content: '✓'; color: var(--orange); }
    .calendar { padding-block: 2rem; }
    .cal-head { border-top: 2px solid var(--ink); padding-top: 1.2rem; margin-bottom: 1.5rem; }
    .region { margin-bottom: 2.2rem; }
    .region-name { font-size: 1.05rem; color: var(--warm); font-family: var(--sans); letter-spacing: 0.04em; border-bottom: 1px solid var(--line); padding-bottom: 0.4rem; }
    .ops { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .op { border: 1px solid var(--line); border-radius: 3px; background: var(--paper); }
    .op-link { display: grid; gap: 0.25rem; padding: 1rem; text-decoration: none; }
    .op:hover { border-color: var(--warm); }
    .op-title { font-family: var(--serif); font-weight: 600; font-size: 1.15rem; }
    .op-summary { font-size: 0.98rem; }
    .op-when { margin-top: 0.3rem; }
    .cal-note { border-top: 1px solid var(--line); padding-top: 1.2rem; }
    .worth-trip { padding-block: 1.5rem; }
    .trip-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 1rem; }
    @media (max-width: 760px) { .trip-grid { grid-template-columns: 1fr; } }
    .trip { display: grid; gap: 0.3rem; padding: 1.2rem; border: 1px solid var(--line); border-radius: 4px; background: var(--cream); text-decoration: none; }
    .trip:hover { border-color: var(--orange); }
    .trip-title { font-family: var(--display); font-weight: 600; font-size: 1.2rem; }
    .latest { padding-block: 2rem 1rem; }
    .story-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-top: 1rem; }
    @media (max-width: 720px) { .story-grid { grid-template-columns: 1fr; } }
    .story { display: grid; gap: 0.35rem; text-decoration: none; border: 1px solid var(--line); border-radius: 4px; overflow: hidden; background: var(--paper); }
    .story img { width: 100%; height: 300px; object-fit: cover; display: block; }
    .story .eyebrow, .story .story-title, .story .muted { padding-inline: 1rem; }
    .story .eyebrow { padding-top: 1rem; }
    .story .muted { padding-bottom: 1rem; }
    .story-title { font-family: var(--serif); font-weight: 600; font-size: 1.3rem; }
    .story:hover { border-color: var(--ember); }
    .gallery-band { padding-block: 2rem 1rem; }
    .gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.8rem; margin-top: 1rem; }
    @media (max-width: 900px) { .gallery { grid-template-columns: repeat(2, 1fr); } }
    .gphoto { margin: 0; }
    .gphoto img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: 3px; display: block; }
    .gphoto figcaption { font-size: 0.74rem; margin-top: 0.3rem; }
    .convert { padding-block: 1.5rem; }
    .convert-card { background: var(--sepia-grad); color: var(--ivory); border-radius: 6px; padding: clamp(1.8rem, 5vw, 3.2rem); box-shadow: 0 1px 40px rgba(20,12,5,0.18); }
    .convert-card h2 { color: var(--ivory); margin: 0.2rem 0 0.6rem; }
    .convert-card .eyebrow { color: var(--warm-light); }
    .convert-card .prose { color: var(--ivory-soft); }
    .sub-lg { display: flex; gap: 0.6rem; margin-top: 1.2rem; max-width: 32rem; }
    .sub-lg input { flex: 1; padding: 0.8em 1em; border: 0; border-radius: 2px; font-family: var(--sans); }
    .depts { padding-block: 2.5rem 1rem; }
    .dept-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 1rem; }
    @media (max-width: 760px) { .dept-grid { grid-template-columns: 1fr; } }
    .dept { display: grid; gap: 0.35rem; padding: 1.3rem; border: 1px solid var(--line); border-radius: 3px; text-decoration: none; background: var(--cream); }
    .dept:hover { border-color: var(--ember); }
    .dept-title { font-family: var(--serif); font-weight: 600; font-size: 1.2rem; }
  </style>
</Base>
