import Base from '../../layouts/Base.astro';
---
<Base path="/studio" title="The Studio" description="A working arm of ArtempireMJ. Co-creation, the Art to Soul series, and the Artist Edition mechanism that feeds exhibitions.">
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="eyebrow">An arm of ArtempireMJ</p>
    <h1>The Studio</h1>
    <p class="lede prose">Where ArtempireMJ makes, not only covers. Co-creation work, the
      Art to Soul series, and the Artist Edition: an editorial theme that artists answer with new
      work, which becomes an exhibition.</p>
  </section>
  <section class="wrap" style="padding-block: 1rem 3rem;">
    <h2>The Artist Edition</h2>
    <p class="muted prose">A theme from a series, Money Stories or Art to Soul, becomes an open
      invitation: artists make work on it. The strongest pieces become a show. The work shown is
      the artists’, alongside them, with them.</p>
    <h2 style="margin-top:2rem;">Co-creation</h2>
    <p class="muted prose">The Studio takes on commissioned and collaborative work with artists and
      partners. <a href="/studio/commission">Talk to the Studio about a commission.</a></p>
  </section>
</Base>
