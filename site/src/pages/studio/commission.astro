---
import Base from '../../layouts/Base.astro';
---
<Base path="/studio/commission" title="Commission a work" description="Commission and co-creation work through the ArtempireMJ Studio.">
  <section class="wrap prose" style="padding-block: clamp(2rem,6vw,4rem) 3rem;">
    <p class="eyebrow">The Studio</p>
    <h1>Commission a work</h1>
    <p class="lede">The Studio takes on a small number of commissioned and collaborative pieces a
      year, with artists and with partners.</p>
    <p class="muted">Tell us what you have in mind, the occasion, the space, the story you want
      held. We will tell you who in the studio is right for it, and what it takes.</p>
    <p style="margin-top:1.5rem;"><a class="btn" href="mailto:studio@artempiremj.com">Write to the Studio</a></p>
  </section>
</Base>
