---
import Base from '../../layouts/Base.astro';
import { ARTICLES } from '../../data/articles.ts';
const stories = ARTICLES.filter((a) => a.series === 'The World');
---
<Base path="/world" title="The World" description="The world, told through its artists. From a fair floor in Johannesburg where a continent argued that its history is its own to keep.">
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="eyebrow">The World</p>
    <h1>The world, through its artists.</h1>
    <p class="lede prose">At FNB Art Joburg the banners read Own history now. Fifteen African countries
      shared one floor, and at the BKhz booth Zandile Tshabalala's Black figures sat at ease, in full
      command of the frame. A continent saying, out loud and in paint, that its history is its own to
      keep. The week's news, in the hands of the people who make its images.</p>
  </section>

  <section class="wrap" style="padding-block: 1rem 3rem;">
    {stories.length > 0 ? (
      <ul class="stories">
        {stories.map((a) => (
          <li class="s">
            {a.image && <a href={`/story/${a.slug}`}><img src={a.image} alt={a.imageAlt} loading="lazy" decoding="async" /></a>}
            <span class="eyebrow">{a.series}{a.byline ? ` · ${a.byline}` : ''}</span>
            <a class="s-title" href={`/story/${a.slug}`}>{a.title}</a>
            <span class="muted">{a.dek}</span>
          </li>
        ))}
      </ul>
    ) : (
      <p class="muted">The first dispatches are on their way from the correspondents.</p>
    )}

    <p class="muted" style="border-top:1px solid var(--line); padding-top:1.4rem; margin-top:2rem;">
      Your work carries a story the world should see? <a href="/submit">Send it to us.</a>
    </p>
  </section>

  <style>
    .stories { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    @media (max-width: 720px) { .stories { grid-template-columns: 1fr; } }
    .s { display: grid; gap: 0.4rem; }
    .s img { width: 100%; height: 260px; object-fit: cover; border-radius: 4px; display: block; }
    .s-title { font-family: var(--serif); font-weight: 600; font-size: 1.5rem; text-decoration: none; color: var(--ink); }
    .s-title:hover { color: var(--ember); }
  </style>
</Base>
