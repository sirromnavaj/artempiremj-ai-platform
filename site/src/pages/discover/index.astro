---
import Base from '../../layouts/Base.astro';
import { OPPORTUNITIES, eventSchema } from '../../data/calendar.ts';
const schema = OPPORTUNITIES.map(eventSchema);
---
<Base path="/discover" title="DISCOVER" description="The opportunity radar: open calls, residencies, grants, and fairs, gathered for the artists who want them. Updated on a four-week global rotation.">
  <set:html set:html={`<script type="application/ld+json">${JSON.stringify(schema)}</script>`} />
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="eyebrow">Department</p>
    <h1>DISCOVER</h1>
    <p class="lede prose">Find the door before it closes. Open calls, residencies, grants, and fairs,
      gathered for the artists who want them. Every date is confirmed before it is listed. Free to
      read, wherever you live.</p>
  </section>

  <figure style="margin:0.5rem auto 1rem;max-width:72rem;padding-inline:var(--pad);">
    <img src="/images/ictaf_owanto.jpg" alt="A gallery booth at the Investec Cape Town Art Fair"
      width="1600" height="760" loading="lazy" decoding="async"
      style="width:100%;height:auto;aspect-ratio:21/9;object-fit:cover;border-radius:4px;display:block;" />
    <figcaption class="muted" style="margin-top:0.4rem;font-size:0.8rem;">Owanto’s solo presentation at the Investec Cape Town Art Fair. Photograph from the ICTAF press pack.</figcaption>
  </figure>

  <section class="wrap" style="padding-block: 1rem;">
    <h2>Two tracks</h2>
    <div class="tracks">
      <div class="track">
        <span class="eyebrow">Track one</span>
        <h3>Africa, in full</h3>
        <p class="muted">Kenya first and exhaustively, then East Africa, then the rest of the
          continent. The festivals, fairs, residencies, and open calls our correspondents reach
          closest. <a href="/festivals">The festivals</a> · <a href="/region/africa">African opportunities</a>.</p>
      </div>
      <div class="track">
        <span class="eyebrow">Track two</span>
        <h3>The world, on rotation</h3>
        <p class="muted">A four-week rotation across the Americas, Europe, Africa, and Asia and the
          Middle East, so coverage reaches every region rather than the same few cities.</p>
      </div>
    </div>
  </section>
  <style>
    .tracks { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-top: 1rem; }
    @media (max-width: 720px) { .tracks { grid-template-columns: 1fr; } }
    .track { padding: 1.3rem; border: 1px solid var(--line); border-radius: 4px; background: var(--cream); }
    .track h3 { margin: 0.3rem 0 0.5rem; }
  </style>

  <section class="wrap" style="padding-block: 1.5rem;">
    <h2>On the radar now</h2>
    <ul class="ops">
      {OPPORTUNITIES.map((o) => (
        <li class="op"><a href={`/opportunity/${o.id}`}>
          <span class="eyebrow">{o.kind}</span>
          <span class="op-title">{o.title}</span>
          <span class="muted">{o.organizer} · {o.city}, {o.country}</span>
          <span>{o.summary}</span>
          <span class="muted">{o.verified && o.deadline ? `Deadline ${o.deadline}` : o.window}</span>
        </a></li>
      ))}
    </ul>
    <p class="muted" style="border-top:1px solid var(--line); padding-top:1.2rem; margin-top:1.5rem;">
      Dates are confirmed before an opportunity is listed. Run a residency, fair, grant, or open
      call? <a href="/list">List it on the calendar.</a></p>
  </section>

  <style>
    .ops { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .op { border: 1px solid var(--line); border-radius: 3px; background: var(--paper); }
    .op a { display: grid; gap: 0.25rem; padding: 1rem; text-decoration: none; }
    .op-title { font-family: var(--serif); font-weight: 600; font-size: 1.15rem; }
  </style>
</Base>
