---
import Base from '../../layouts/Base.astro';
import Newsletter from '../../components/Newsletter.astro';
import { ARTICLES, type Article } from '../../data/articles.ts';

export function getStaticPaths() {
  return ARTICLES.map((a) => ({ params: { slug: a.slug }, props: { a } }));
}
const { a } = Astro.props as { a: Article };
const site = 'https://artempiremj.com';
const path = `/story/${a.slug}`;
const article = {
  '@context': 'https://schema.org',
  '@type': a.series === 'The World' ? 'NewsArticle' : 'Article',
  headline: a.title, description: a.dek,
  datePublished: a.date, dateModified: a.date,
  image: a.image ? site + a.image : undefined,
  author: a.byline ? { '@type': 'Person', name: a.byline }
                    : { '@type': 'Organization', name: 'ArtempireMJ' },
  publisher: { '@type': 'Organization', name: 'ArtempireMJ', url: site },
  articleSection: a.series,
  mainEntityOfPage: site + path,
};
---
<Base path={path} title={a.title} description={a.dek}>
  <set:html set:html={`<script type="application/ld+json">${JSON.stringify(article)}</script>`} />

  <article class="wrap" style="padding-block: clamp(2rem,6vw,3.5rem) 2rem; max-width: 46rem;">
    <p class="muted" style="font-family:var(--sans);font-size:0.85rem;">
      <a href="/spotlight">Spotlight</a> · {a.series}
    </p>
    <p class="eyebrow">{a.series}</p>
    <h1>{a.title}</h1>
    <p class="lede">{a.dek}</p>
    {a.byline && <p class="muted">By {a.byline}</p>}

    {a.image && (
      <figure class="story-fig">
        <img src={a.image} alt={a.imageAlt} loading="eager" decoding="async" />
        {a.credit && <figcaption class="muted">{a.credit}</figcaption>}
      </figure>
    )}

    <div class="prose body">
      {a.body.map((b) => (
        typeof b === 'string' ? <p>{b}</p>
        : 'h' in b ? <h2 class="sub">{b.h}</h2>
        : <blockquote class="pull"><p>{b.quote}</p>{b.cite && <cite>{b.cite}</cite>}</blockquote>
      ))}
    </div>

    <hr />
    <p class="muted">More from the floor, once a week. Free.</p>
    <Newsletter variant="inline" source="story" />
  </article>

  <style>
    .story-fig { margin: 1.5rem 0; }
    .story-fig img { display: block; max-width: 100%; max-height: 560px; width: auto; height: auto; margin: 0 auto; border-radius: 4px; }
    .story-fig figcaption { margin-top: 0.5rem; font-size: 0.85rem; text-align: center; }
    .body p { margin: 0 0 1.1rem; font-size: 1.12rem; line-height: 1.7; }
    .body .sub { font-size: 1.4rem; margin: 2rem 0 0.8rem; }
    .body .pull { margin: 1.8rem 0; padding-left: 1.2rem; border-left: 3px solid var(--orange); }
    .body .pull p { font-family: var(--display); font-size: 1.35rem; line-height: 1.4; font-style: italic; margin: 0 0 0.4rem; }
    .body .pull cite { font-family: var(--sans); font-size: 0.85rem; color: var(--muted); font-style: normal; }
  </style>
</Base>
