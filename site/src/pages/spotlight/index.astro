---
import Base from '../../layouts/Base.astro';
import { SERIES, WEEKLY } from '../../data/series.ts';
import { ARTICLES } from '../../data/articles.ts';
import Newsletter from '../../components/Newsletter.astro';
const series = SERIES.filter((s) => s.department === 'Spotlight');
const stories = ARTICLES.filter((a) => a.department === 'Spotlight');
---
<Base path="/spotlight" title="Spotlight" description="News, analysis, and artist features through the maker’s eye. The World column, Money Stories, Art + Finance, Ink, and more.">
  <section class="wrap" style="padding-block: clamp(2rem,6vw,4rem) 1rem;">
    <p class="eyebrow">Department</p>
    <h1>Spotlight</h1>
    <p class="lede prose">News, analysis, and artist features through the maker’s eye. When something
      happens in the world, Spotlight finds the artist who carries it and tells it through them.</p>
  </section>

  <section class="wrap" style="padding-block: 1rem 1.5rem;">
    <div class="collector panel-dark">
      <p class="eyebrow">Art + Finance</p>
      <h2>For the people who move money in art.</h2>
      <p class="prose">The art market's economics, read by the artists who live inside it. Where capital
        is placing its next bet, which prizes are repricing whose work, what the new money is buying
        before the market catches up. The intelligence tier is coming. Get the edge first.</p>
      <div style="max-width:30rem;margin-top:1rem;"><Newsletter variant="inline" source="art-finance" /></div>
    </div>
  </section>

  <section class="wrap" style="padding-block: 1rem;">
    <h2>Latest</h2>
    <ul class="series">
      {stories.map((a) => (
        <li class="s">
          <span class="eyebrow">{a.series}</span>
          <a class="s-name" href={`/story/${a.slug}`} style="text-decoration:none;">{a.title}</a>
          <span class="muted">{a.dek}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="wrap" style="padding-block: 1rem;">
    <h2>The series</h2>
    <ul class="series">
      {series.map((s) => (
        <li class="s">
          <span class="eyebrow">{s.day ?? 'Series'}</span>
          <span class="s-name">{s.name}</span>
          <span class="muted">{s.what}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="wrap" style="padding-block: 1.5rem 3rem;">
    <h2>The week</h2>
    <p class="muted prose">The slots run regardless of the monthly theme. The theme is the connective tissue between them.</p>
    <table class="week">
      <tbody>
        {WEEKLY.map(([day, what]) => (<tr><th>{day}</th><td>{what}</td></tr>))}
      </tbody>
    </table>
  </section>

  <style>
    .series { list-style: none; padding: 0; margin: 1rem 0 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
    .s { display: grid; gap: 0.3rem; padding: 1.1rem; border: 1px solid var(--line); border-radius: 3px; background: var(--paper); }
    .s-name { font-family: var(--serif); font-weight: 600; font-size: 1.2rem; }
    .week { border-collapse: collapse; margin-top: 1rem; font-family: var(--sans); }
    .week th { text-align: left; padding: 0.5rem 1.5rem 0.5rem 0; color: var(--warm); font-weight: 600; }
    .week td { padding: 0.5rem 0; border-bottom: 1px solid var(--line); }
    .collector { border-radius: 6px; padding: clamp(1.6rem, 4vw, 2.6rem); box-shadow: 0 1px 40px rgba(20,12,5,0.18); }
    .collector .prose { max-width: 60ch; }
  </style>
</Base>
